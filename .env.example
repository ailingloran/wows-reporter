# ── Statbot ──────────────────────────────────────────────
# Your Statbot API key (from https://statbot.net/dashboard → API)
STATBOT_API_KEY=your_statbot_api_key_here

# Your Discord server (guild) ID — right-click server icon → Copy Server ID
STATBOT_GUILD_ID=123456789012345678

# ── Discord ──────────────────────────────────────────────
# Bot token from discord.com/developers/applications → Your App → Bot → Token
DISCORD_BOT_TOKEN=your_bot_token_here

# Channel ID where daily reports are posted (staff-only channel)
DISCORD_STAFF_CHANNEL_ID=123456789012345678

# Channel ID where monthly draft reports are posted for approval
DISCORD_MONTHLY_CHANNEL_ID=123456789012345678

# Role ID of the @Player role to track
DISCORD_PLAYER_ROLE_ID=123456789012345678

# Comma-separated role IDs of staff roles (can use /report and /snapshot slash commands)
DISCORD_STAFF_ROLE_IDS=123456789012345678,987654321098765432

# Comma-separated role IDs of admin roles (can use /sentiment slash commands)
DISCORD_ADMIN_ROLE_IDS=123456789012345678

# ── Scheduling (all in Europe/Berlin timezone) ────────────
# Daily report cron — default: midnight CET
DAILY_CRON=0 0 * * *

# Monthly report cron — default: midnight on 1st of each month
MONTHLY_CRON=0 0 1 * *

# ── Delivery Mode ─────────────────────────────────────────
# Options: 'discord' | 'dashboard' | 'both'
DAILY_DELIVERY=discord
MONTHLY_DELIVERY=both

# ── Monthly approval mode ──────────────────────────────────
# true = post draft with Approve/Edit buttons; false = publish immediately
MONTHLY_APPROVAL_MODE=true

# ── Web Dashboard ──────────────────────────────────────────
DASHBOARD_PORT=3000
# Password to access the dashboard (basic auth)
DASHBOARD_SECRET=change_me_to_a_strong_password

# ── Report Window ──────────────────────────────────────────
# Options: 'calendarDay' | 'rolling24h'  (calendarDay recommended)
DAILY_WINDOW=calendarDay

# ── Logging ───────────────────────────────────────────────
# Options: 'error' | 'warn' | 'info' | 'debug'
LOG_LEVEL=info

# ── Community Pulse (OpenAI sentiment analysis) ────────────
# API key from platform.openai.com — leave blank to disable the feature entirely
OPENAI_API_KEY=sk-...

# Comma-separated channel IDs to sample messages from (e.g. game-discussion, general-feedback)
SENTIMENT_CHANNEL_IDS=123456789012345678,987654321098765432

# Cron schedule for the Community Pulse report (default: 17:00 Berlin time daily)
SENTIMENT_CRON=0 17 * * *
